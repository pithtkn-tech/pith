# Pith Configuration
# Copy to .env and customize

# Server
PITH_HOST=0.0.0.0
PITH_PORT=8000
PITH_DEBUG=false

# Default LLM provider (users can override per-request)
PITH_DEFAULT_BASE_URL=https://api.openai.com/v1
PITH_DEFAULT_API_KEY=sk-your-key-here

# Optimizer
PITH_OPTIMIZER=true
PITH_MIN_TOKENS=50

# Injection detection
PITH_INJECTION=true
PITH_INJECTION_THRESHOLD=0.70
PITH_INJECTION_ACTION=sanitize  # sanitize | block | log

# Compression mode
PITH_COMPRESSION=balanced  # aggressive | balanced | conservative | none

# Logging
PITH_LOG_LEVEL=info
